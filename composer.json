{
    "name": "nubitio/tenant-bundle",
    "description": "Opt-in column-tenant kit for Nubit Symfony apps: TenantScoped attribute, Doctrine filter, context resolver, and registry.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "bundle",
        "multi-tenant",
        "saas",
        "nubit"
    ],
    "homepage": "https://github.com/nubitio/nubit-symfony/tree/main/packages/tenant-bundle",
    "support": {
        "issues": "https://github.com/nubitio/nubit-symfony/issues",
        "source": "https://github.com/nubitio/nubit-symfony"
    },
    "require": {
        "php": ">=8.5",
        "doctrine/orm": "^3.0",
        "firebase/php-jwt": "^7.0",
        "nubitio/platform": "0.*",
        "symfony/config": "^7.4 || ^8.0",
        "symfony/console": "^7.4 || ^8.0",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/doctrine-bridge": "^7.4 || ^8.0",
        "symfony/framework-bundle": "^7.4 || ^8.0",
        "symfony/http-foundation": "^7.4 || ^8.0",
        "symfony/http-kernel": "^7.4 || ^8.0",
        "symfony/security-core": "^7.4 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Nubit\\TenantBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nubit\\TenantBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}